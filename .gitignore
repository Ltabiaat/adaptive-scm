# ---------------------------------------------------------------------------
# Project-specific (large / generated)
# ---------------------------------------------------------------------------
# Raw M5 data — too large for git, download separately
data/raw/*
!data/raw/.gitkeep

# Processed parquet files — regeneratable from raw
data/processed/*
!data/processed/.gitkeep

# Experiment outputs — regeneratable
results/forecasts/*
!results/forecasts/.gitkeep
results/simulations/*
!results/simulations/.gitkeep
results/analysis/*
!results/analysis/.gitkeep

# Model checkpoints
*.zip
*.pt
*.pth
*.pkl
*.joblib

# Logs
logs/
*.log

